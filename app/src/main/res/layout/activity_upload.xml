<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"
        app:title="@string/title_upload"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- File preview -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/card_dark"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/img_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_no_file"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/no_file_selected"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:textSize="14sp" />
            </FrameLayout>

            <Button
                android:id="@+id/btn_select_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_select_file"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_title"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:inputType="text"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_description"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="16dp" />

            <!-- GPS section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_auto_gps"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/switch_auto_gps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_manual_gps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/et_latitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_latitude"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:inputType="numberDecimal|numberSigned"
                    android:backgroundTint="@color/primary"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/et_longitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_longitude"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:inputType="numberDecimal|numberSigned"
                    android:backgroundTint="@color/primary" />
            </LinearLayout>

            <!-- Quality spinner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_quality"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_dark"
                android:layout_marginBottom="16dp" />

            <!-- Processing options -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_options"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/cb_depth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opt_depth_estimation"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:buttonTint="@color/primary" />

            <CheckBox
                android:id="@+id/cb_mesh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opt_mesh_generation"
                android:textColor="@color/text_primary"
                android:checked="false"
                android:buttonTint="@color/primary" />

            <CheckBox
                android:id="@+id/cb_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opt_color_correction"
                android:textColor="@color/text_primary"
                android:checked="true"
                android:buttonTint="@color/primary" />

            <CheckBox
                android:id="@+id/cb_hdr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/opt_hdr"
                android:textColor="@color/text_primary"
                android:checked="false"
                android:buttonTint="@color/primary"
                android:layout_marginBottom="16dp" />

            <ProgressBar
                android:id="@+id/progress_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/tv_upload_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_upload_process"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
