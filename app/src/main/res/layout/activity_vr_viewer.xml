<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Cardboard split line -->
    <View
        android:id="@+id/divider_vr"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_horizontal"
        android:background="@color/black"
        android:visibility="gone" />

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/black">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vr_loading"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Controls overlay (top) -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/overlay"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_rew"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white" />

        <TextView
            android:id="@+id/tv_vr_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_vr"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:gravity="center" />

        <ToggleButton
            android:id="@+id/btn_toggle_cardboard"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:textOn="Cardboard ON"
            android:textOff="Cardboard OFF"
            android:textSize="11sp"
            android:checked="false" />
    </LinearLayout>

    <!-- Video controls (bottom) — visible only in video mode -->
    <LinearLayout
        android:id="@+id/layout_video_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/overlay"
        android:padding="8dp"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/seekbar_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_media_pause"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white" />

            <TextView
                android:id="@+id/tv_video_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00 / 0:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_video_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO 360°"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hint text -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:text="@string/vr_gyroscope_hint"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:background="@color/overlay"
        android:padding="8dp" />
</FrameLayout>
